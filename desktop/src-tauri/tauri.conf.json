{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MiniMax Studio",
  "version": "0.4.1",
  "identifier": "com.minimax.agent.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MiniMax Studio",
        "width": 1320,
        "height": 860,
        "minWidth": 1040,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["msi", "nsis", "dmg", "appimage", "deb"],
    "resources": {
      "../../dist/backend": "backend"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "MiniMax Studio - AI-powered desktop assistant",
    "longDescription": "Professional desktop app for the MiniMax Studio platform with multi-expert support, code workspace, and persistent memory.",
    "publisher": "MiniMax",
    "copyright": "Copyright (c) 2026 MiniMax"
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/eduardoabreu81/minimax-agent-gui/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlEMDE4RUI0QjgyQ0VDOEEKUldTSzdDeTR0STRCblhJVGZSSGdyVVhmbUVKMUhKWGZZc2RzaDJPU3k1RGFWVUVad0ZUQ2FwQ20K",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
