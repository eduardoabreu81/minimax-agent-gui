# Internal docs — never commit analysis, roadmaps, or project logs
ANALISE_*.md
PROJECT_*.md
ROADMAP_*.md
INTEGRATION_REPORT.md
CONTRIBUTING.md
*.local.md
docs/*.md

# Node.js
node_modules/
dist/
build/

# OS
.DS_Store
Thumbs.db

# Local dev scripts (Windows)
start.bat
close.bat

# Runtime artifacts
web/server.pid

# Scratch / one-off test scripts (not part of the test suite)
test_*.py
!tests/test_*.py

# Unrelated side project (a separate Node.js landing page that lives inside web/backend/)
web/backend/server.js
web/backend/package.json
web/backend/landing-page.html
web/backend/public/
web/backend/visitors.json

# Local tool sessions (per-dev, not part of the project)
.claude/
.mavis/
.specstory/
.opencode/

# Public documentation assets — re-include despite the broad *.png and
# docs/*.md ignores above. These are referenced by the public README and
# MUST be committed. (CONTRIBUTING.md stays ignored on purpose — it's a
# local dev note, not a published doc.)
!docs/assets/*.png
!docs/USER_GUIDE.md
!desktop/docs/screenshots/*.png